<Window x:Class="GamePulseMonitor.ScreenshotSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Cursor="Cross"
        Focusable="True"
        KeyDown="OnKeyDown"
        MouseLeftButtonDown="OnMouseLeftButtonDown"
        MouseLeftButtonUp="OnMouseLeftButtonUp"
        MouseMove="OnMouseMove">
    <Window.Resources>
        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Foreground" Value="#F5F7FB"/>
            <Setter Property="Background" Value="#263342"/>
            <Setter Property="BorderBrush" Value="#53657A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SwatchButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderBrush" Value="#53657A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Canvas x:Name="RootCanvas"
            Background="Transparent">
        <Image x:Name="FrozenImage"
               Stretch="Fill"
               IsHitTestVisible="False"/>
        <Path x:Name="DimPath"
              Fill="#66000000"
              IsHitTestVisible="False"/>
        <Canvas x:Name="CaptureLayer"
                Visibility="Collapsed"
                ClipToBounds="True"
                Background="Transparent">
            <Image x:Name="CaptureImage"
                   Stretch="Fill"
                   IsHitTestVisible="False"/>
            <Canvas x:Name="AnnotationCanvas"
                    Background="Transparent"
                    ClipToBounds="True"/>
        </Canvas>
        <Border x:Name="SelectionBorder"
                BorderBrush="#7DE3FF"
                BorderThickness="2"
                Background="#18FFFFFF"
                Visibility="Collapsed"
                IsHitTestVisible="False"/>
        <Border x:Name="InfoPanel"
                Padding="10,7"
                Background="#DD101827"
                BorderBrush="#667DE3FF"
                BorderThickness="1"
                CornerRadius="4"
                IsHitTestVisible="False">
            <TextBlock x:Name="InfoText"
                       Foreground="#F5F7FB"
                       FontSize="13"/>
        </Border>
        <Border x:Name="RgbPanel"
                Visibility="Collapsed"
                Padding="9,6"
                Background="#EE101827"
                BorderBrush="#667DE3FF"
                BorderThickness="1"
                CornerRadius="4"
                IsHitTestVisible="False">
            <TextBlock x:Name="RgbText"
                       MinWidth="148"
                       Foreground="#D8E2EF"
                       FontSize="12"
                       Text="RGB --"/>
        </Border>
        <Border x:Name="ToolPanel"
                Visibility="Collapsed"
                Padding="6"
                Background="#EE101827"
                BorderBrush="#667DE3FF"
                BorderThickness="1"
                CornerRadius="4">
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="ArrowButton"
                            Style="{StaticResource ToolButtonStyle}"
                            Click="OnArrowClick">
                        <Path Stretch="Uniform"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="2.4"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M5,20 L21,4 M13,4 L21,4 L21,12"/>
                    </Button>
                    <Button x:Name="ShapeButton"
                            Style="{StaticResource ToolButtonStyle}"
                            Click="OnShapeClick">
                        <Rectangle Width="17"
                                   Height="13"
                                   Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   StrokeThickness="2"
                                   Fill="Transparent"/>
                    </Button>
                    <Button x:Name="PenButton"
                            Style="{StaticResource ToolButtonStyle}"
                            Click="OnPenClick">
                        <Path Stretch="Uniform"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M4,20 L16,8 L20,12 L8,24 L3,25 Z M14,10 L18,14"/>
                    </Button>
                    <Button x:Name="TextButton"
                            Style="{StaticResource ToolButtonStyle}"
                            Click="OnTextClick">
                        <TextBlock Text="T"
                                   FontWeight="SemiBold"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="MosaicButton"
                            Style="{StaticResource ToolButtonStyle}"
                            Click="OnMosaicClick">
                        <Grid Width="18" Height="18">
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Row="0" Grid.Column="0" Margin="1" Fill="#F5F7FB"/>
                            <Rectangle Grid.Row="0" Grid.Column="1" Margin="1" Fill="#8EA0B6"/>
                            <Rectangle Grid.Row="0" Grid.Column="2" Margin="1" Fill="#F5F7FB"/>
                            <Rectangle Grid.Row="1" Grid.Column="0" Margin="1" Fill="#8EA0B6"/>
                            <Rectangle Grid.Row="1" Grid.Column="1" Margin="1" Fill="#F5F7FB"/>
                            <Rectangle Grid.Row="1" Grid.Column="2" Margin="1" Fill="#8EA0B6"/>
                            <Rectangle Grid.Row="2" Grid.Column="0" Margin="1" Fill="#F5F7FB"/>
                            <Rectangle Grid.Row="2" Grid.Column="1" Margin="1" Fill="#8EA0B6"/>
                            <Rectangle Grid.Row="2" Grid.Column="2" Margin="1" Fill="#F5F7FB"/>
                        </Grid>
                    </Button>
                    <Button x:Name="EraserButton"
                            Style="{StaticResource ToolButtonStyle}"
                            Click="OnEraserClick">
                        <Path Stretch="Uniform"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M5,17 L14,8 C15,7 16,7 17,8 L21,12 C22,13 22,14 21,15 L14,22 L7,22 L3,18 Z M8,16 L14,22"/>
                    </Button>
                    <Rectangle Width="1"
                               Height="24"
                               Margin="6,0"
                               Fill="#53657A"/>
                    <Button x:Name="UndoButton"
                            Style="{StaticResource ToolButtonStyle}"
                            Click="OnUndoClick">
                        <Path Stretch="Uniform"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="2.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Data="M10,7 L4,13 L10,19 M5,13 L16,13 C21,13 23,17 20,21"/>
                    </Button>
                    <Button x:Name="RedoButton"
                            Style="{StaticResource ToolButtonStyle}"
                            Click="OnRedoClick">
                        <Path Stretch="Uniform"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="2.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Data="M14,7 L20,13 L14,19 M19,13 L8,13 C3,13 1,17 4,21"/>
                    </Button>
                    <Rectangle Width="1"
                               Height="24"
                               Margin="6,0"
                               Fill="#53657A"/>
                    <Button x:Name="CancelButton"
                            Style="{StaticResource ToolButtonStyle}"
                            Click="OnCancelClick">
                        <Path Stretch="Uniform"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="2.4"
                              StrokeStartLineCap="Round"
                              Data="M6,6 L20,20 M20,6 L6,20"/>
                    </Button>
                    <Button x:Name="PinButton"
                            Style="{StaticResource ToolButtonStyle}"
                            Click="OnPinClick">
                        <Path Stretch="Uniform"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M9,3 L19,3 L17,9 L21,13 L14,13 L13,23 L11,23 L10,13 L3,13 L7,9 Z"/>
                    </Button>
                    <Button x:Name="SaveButton"
                            Style="{StaticResource ToolButtonStyle}"
                            Click="OnSaveClick">
                        <Path Stretch="Uniform"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="2"
                              StrokeLineJoin="Round"
                              Data="M5,4 L18,4 L22,8 L22,22 L5,22 Z M8,4 L8,11 L18,11 L18,4 M9,22 L9,15 L18,15 L18,22"/>
                    </Button>
                    <Button x:Name="CopyButton"
                            Style="{StaticResource ToolButtonStyle}"
                            Click="OnCopyClick">
                        <Path Stretch="Uniform"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="2"
                              StrokeLineJoin="Round"
                              Data="M8,8 L18,8 L18,22 L8,22 Z M5,4 L15,4 L15,8 M5,4 L5,18 L8,18"/>
                    </Button>
                </StackPanel>
                <StackPanel x:Name="MarkerOptionsPanel"
                            Orientation="Horizontal"
                            Visibility="Collapsed"
                            Margin="2,7,2,0">
                    <StackPanel x:Name="ShapeOptionsPanel"
                                Orientation="Horizontal"
                                Visibility="Collapsed"
                                Margin="0,0,8,0">
                        <Button x:Name="RectangleShapeButton"
                                Style="{StaticResource ToolButtonStyle}"
                                Click="OnRectangleShapeClick">
                            <Rectangle Width="17"
                                       Height="13"
                                       Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       StrokeThickness="2"
                                       Fill="Transparent"/>
                        </Button>
                        <Button x:Name="EllipseShapeButton"
                                Style="{StaticResource ToolButtonStyle}"
                                Click="OnEllipseShapeClick">
                            <Ellipse Width="17"
                                     Height="13"
                                     Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                     StrokeThickness="2"
                                     Fill="Transparent"/>
                        </Button>
                        <Button x:Name="StarShapeButton"
                                Style="{StaticResource ToolButtonStyle}"
                                Click="OnStarShapeClick">
                            <Polygon Points="10,1 12.6,7 19,7.4 14,11.5 15.6,18 10,14.5 4.4,18 6,11.5 1,7.4 7.4,7"
                                     Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                     StrokeThickness="2"
                                     Fill="Transparent"
                                     Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                    <StackPanel x:Name="ColorOptionsPanel"
                                Orientation="Horizontal">
                        <Button x:Name="ColorRedButton"
                                Style="{StaticResource SwatchButtonStyle}"
                                Background="#FF4D4D"
                                Tag="#FF4D4D"
                                Click="OnColorClick"/>
                        <Button x:Name="ColorAmberButton"
                                Style="{StaticResource SwatchButtonStyle}"
                                Background="#FFB020"
                                Tag="#FFB020"
                                Click="OnColorClick"/>
                        <Button x:Name="ColorGreenButton"
                                Style="{StaticResource SwatchButtonStyle}"
                                Background="#31D07F"
                                Tag="#31D07F"
                                Click="OnColorClick"/>
                        <Button x:Name="ColorCyanButton"
                                Style="{StaticResource SwatchButtonStyle}"
                                Background="#38BDF8"
                                Tag="#38BDF8"
                                Click="OnColorClick"/>
                        <Button x:Name="ColorVioletButton"
                                Style="{StaticResource SwatchButtonStyle}"
                                Background="#A78BFA"
                                Tag="#A78BFA"
                                Click="OnColorClick"/>
                        <Button x:Name="ColorWhiteButton"
                                Style="{StaticResource SwatchButtonStyle}"
                                Background="#FFFFFF"
                                Tag="#FFFFFF"
                                Click="OnColorClick"/>
                    </StackPanel>
                    <StackPanel x:Name="SizeOptionsPanel"
                                Orientation="Horizontal"
                                Margin="8,0,0,0"
                                Visibility="Collapsed">
                        <Button x:Name="SizeDownButton"
                                Style="{StaticResource ToolButtonStyle}"
                                Click="OnSizeDownClick">
                            <Path Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2.2"
                                  StrokeStartLineCap="Round"
                                  Data="M6,13 L20,13"/>
                        </Button>
                        <Border Width="36"
                                Height="30"
                                Margin="2,0"
                                Background="#263342"
                                BorderBrush="#53657A"
                                BorderThickness="1">
                            <TextBlock x:Name="SizeValueText"
                                       Foreground="#D8E2EF"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <Button x:Name="SizeUpButton"
                                Style="{StaticResource ToolButtonStyle}"
                                Click="OnSizeUpClick">
                            <Path Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2.2"
                                  StrokeStartLineCap="Round"
                                  Data="M6,13 L20,13 M13,6 L13,20"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Canvas>
</Window>
