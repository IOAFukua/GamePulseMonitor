<Window x:Class="GamePulseMonitor.PinnedScreenshotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="True"
        KeyDown="OnKeyDown"
        MouseLeftButtonDown="OnMouseLeftButtonDown"
        MouseLeftButtonUp="OnMouseLeftButtonUp"
        MouseMove="OnMouseMove"
        MouseWheel="OnMouseWheel"
        MouseRightButtonDown="OnMouseRightButtonDown">
    <Border x:Name="RootBorder"
            BorderBrush="#CC7DE3FF"
            BorderThickness="1"
            Background="Transparent">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem x:Name="CopyMenuItem"
                          Header="Copy"
                          Click="OnCopyClick"/>
                <MenuItem x:Name="SaveMenuItem"
                          Header="Save"
                          Click="OnSaveClick"/>
                <Separator/>
                <MenuItem x:Name="DestroyMenuItem"
                          Header="Destroy"
                          Click="OnDestroyClick"/>
            </ContextMenu>
        </Border.ContextMenu>
        <Image x:Name="PinnedImage"
               Stretch="Fill"/>
    </Border>
</Window>
