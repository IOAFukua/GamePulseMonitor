<Window x:Class="GamePulseMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GamePulseMonitor"
        Icon="Assets/GamePulseMonitor.ico"
        Width="312"
        Height="270"
        MinWidth="180"
        MinHeight="64"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None">
    <Window.Resources>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAB3C5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F5F7FB"/>
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Viewbox x:Name="OverlayViewbox"
                 Stretch="Fill">
            <Border x:Name="OverlayBorder"
                    Width="312"
                    Height="270"
                    CornerRadius="8"
                    Background="#E50B111D"
                    BorderBrush="#42516A"
                    BorderThickness="1"
                    Padding="14">
                <Grid x:Name="OverlayGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid x:Name="HeaderRow" Grid.Row="0" Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="TargetText"
                                       Foreground="#F5F7FB"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="StatusText"
                                       Margin="0,2,0,0"
                                       Foreground="#7F8DA6"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <TextBlock x:Name="LiveText"
                                   Grid.Column="1"
                                   Text="LIVE"
                                   Foreground="#58D68D"
                                   FontFamily="Cascadia Mono, Consolas"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="12,2,0,0"/>
                    </Grid>

                    <StackPanel x:Name="MetricPanel" Grid.Row="2">
                        <Grid x:Name="FpsRow" Height="30" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="98"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="FpsLabel" Style="{StaticResource LabelText}" Text="FPS"/>
                            <TextBlock x:Name="FpsText" Grid.Column="1" Style="{StaticResource ValueText}" Text="--"/>
                        </Grid>

                        <Grid x:Name="AverageRow" Height="30" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="98"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="AverageLabel" Style="{StaticResource LabelText}" Text="AVG FPS"/>
                            <TextBlock x:Name="AverageText" Grid.Column="1" Style="{StaticResource ValueText}" Text="--"/>
                        </Grid>

                        <Grid x:Name="LowRow" Height="30" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="98"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LowLabel" Style="{StaticResource LabelText}" Text="1% LOW"/>
                            <TextBlock x:Name="LowText" Grid.Column="1" Style="{StaticResource ValueText}" Text="--"/>
                        </Grid>

                        <Grid x:Name="CpuRow" Height="30" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="98"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CpuLabel" Style="{StaticResource LabelText}" Text="CPU"/>
                            <TextBlock x:Name="CpuText" Grid.Column="1" Style="{StaticResource ValueText}" Text="--"/>
                        </Grid>

                        <Grid x:Name="GpuRow" Height="30" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="98"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="GpuLabel" Style="{StaticResource LabelText}" Text="GPU"/>
                            <TextBlock x:Name="GpuText" Grid.Column="1" Style="{StaticResource ValueText}" Text="--"/>
                        </Grid>

                        <Grid x:Name="VramRow" Height="30" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="98"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="VramLabel" Style="{StaticResource LabelText}" Text="VRAM"/>
                            <TextBlock x:Name="VramText" Grid.Column="1" Style="{StaticResource ValueText}" Text="--"/>
                        </Grid>

                        <Grid x:Name="MemoryRow" Height="30" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="98"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="MemoryLabel" Style="{StaticResource LabelText}" Text="RAM"/>
                            <TextBlock x:Name="MemoryText" Grid.Column="1" Style="{StaticResource ValueText}" Text="--"/>
                        </Grid>

                        <Grid x:Name="FrameTimeRow" Height="30" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="98"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="FrameTimeLabel" Style="{StaticResource LabelText}" Text="FT"/>
                            <TextBlock x:Name="FrameTimeText" Grid.Column="1" Style="{StaticResource ValueText}" Text="--"/>
                        </Grid>
                    </StackPanel>

                    <TextBlock x:Name="FooterText"
                               Grid.Row="4"
                               Foreground="#7F8DA6"
                               FontFamily="Cascadia Mono, Consolas"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>
        </Viewbox>

        <Button x:Name="MinimizeButton"
                Content="-"
                Width="22"
                Height="18"
                Padding="0"
                Margin="0,4,4,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                Foreground="#F5F7FB"
                FontFamily="Cascadia Mono, Consolas"
                FontSize="14"
                FontWeight="SemiBold"
                Cursor="Hand"
                Focusable="False"
                IsHitTestVisible="False"
                Opacity="0"
                Visibility="Hidden"
                PreviewMouseDown="OnMinimizePreviewMouseDown"
                Click="OnMinimizeClick">
            <Button.Template>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="Transparent">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <primitives:Thumb x:Name="ResizeThumb"
                          Width="18"
                          Height="18"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Cursor="SizeNWSE"
                          Visibility="Collapsed"
                          DragDelta="OnResizeThumbDragDelta"
                          DragCompleted="OnResizeThumbDragCompleted">
            <primitives:Thumb.Template>
                <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                    <Grid Background="Transparent">
                        <Path Data="M 5 15 L 15 5 M 10 15 L 15 10 M 15 15 L 15 14"
                              Stroke="#AAB3C5"
                              StrokeThickness="1.4"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"/>
                    </Grid>
                </ControlTemplate>
            </primitives:Thumb.Template>
        </primitives:Thumb>
    </Grid>
</Window>
